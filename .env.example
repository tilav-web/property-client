# ============================================================================
# COUNTRY / REGION (server bilan mos kelishi shart)
# ----------------------------------------------------------------------------
# VITE_COUNTRY              - UZ | MY (default: UZ)
# VITE_DEFAULT_CURRENCY     - UZS | MYR | USD ... (default: COUNTRY ga qarab)
# VITE_DEFAULT_LANGUAGE     - uz | ru | en | ms
# VITE_SUPPORTED_LANGUAGES  - vergul orqali (uz,ru,en yoki en,ms)
# VITE_DEFAULT_MAP_CENTER   - "lat,lng" (Toshkent: 41.2995,69.2401;
#                             Kuala Lumpur: 3.139,101.6869)
# VITE_DEFAULT_MAP_ZOOM     - 12 ga yaqin son
# VITE_PHONE_COUNTRY_CODE   - +998 | +60
# ============================================================================
VITE_COUNTRY = UZ
VITE_DEFAULT_CURRENCY = UZS
VITE_DEFAULT_LANGUAGE = uz
VITE_SUPPORTED_LANGUAGES = uz,ru,en
VITE_DEFAULT_MAP_CENTER = 41.2995,69.2401
VITE_DEFAULT_MAP_ZOOM = 12
VITE_PHONE_COUNTRY_CODE = +998

# ============================================================================
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# VITE_PHONE_AUTH_ENABLED — telefon raqam orqali register/login/forgot
#   - true: UZ deploy (Eskiz SMS provider mavjud)
#   - false yoki o'rnatilmagan: MY deploy (Malaysia'da SMS yo'q)
# ============================================================================
VITE_PHONE_AUTH_ENABLED = true
